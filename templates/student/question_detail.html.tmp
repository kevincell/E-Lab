{% extends "base.html" %}
{% block content %}
<section class="toolbar">
  <div>
    <h1>{{ question.title }}</h1>
    <p class="muted">{{ question.module.name }} · {{ question.get_difficulty_display }}</p>
  </div>
  <a class="secondary as-link" href="{% url 'module_detail' question.module.id %}">Back</a>
</section>

<section class="grid two">
  <article class="panel">
    <h2>Problem</h2>
    <div class="prose">{{ question.description|linebreaks }}</div>
    {% if question.sample_input or question.sample_output %}
      <h3>Sample Input</h3>
      <pre>{{ question.sample_input }}</pre>
      <h3>Sample Output</h3>
      <pre>{{ question.sample_output }}</pre>
    {% endif %}
  </article>

  <article class="panel">
    <h2>Submit Code</h2>
    <form method="post" class="form-grid submit-form" data-submit-form>
      {% csrf_token %}
      {{ form.code.errors }}
      {{ form.code }}
      <div id="editor" class="monaco-editor"></div>
      <button class="primary submit-button" type="submit" data-submit-button>
        <span>Submit</span>
        <i aria-hidden="true"></i>
      </button>

      <div class="submit-progress" data-submit-progress aria-hidden="true" role="status" aria-live="polite">
        <div class="submit-progress-bar" aria-hidden="true">
          <div class="submit-progress-fill" data-submit-progress-fill></div>
        </div>
        <div class="submit-progress-label" data-submit-progress-label>
          Submitting…
        </div>
        <div class="submit-progress-hint muted" data-submit-progress-hint>
          Your code is being queued for evaluation.
        </div>
      </div>

    </form>
    {% if latest_submission %}
      <p class="muted">Latest: <a href="{% url 'submission_detail' latest_submission.id %}">{{ latest_submission.get_status_display }}</a></p>
    {% endif %}

    <div class="live-submission" data-live-submission>
      <div class="status-row" aria-live="polite">
        <span class="status-pill status-pending" data-live-status-pill>Waiting for submission…</span>
        <span class="muted" data-live-submission-hint></span>
      </div>
      <div class="live-progress" aria-hidden="true">
        <div class="live-progress-bar"><div class="live-progress-fill" data-live-progress-fill></div></div>
      </div>
    </div>
  </article>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs/loader.min.js"></script>
<script>
  require.config({ paths: { "vs": "https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.44.0/min/vs" } });
  require(["vs/editor/editor.main"], function() {
    const textarea = document.getElementById("id_code");
    const editorNode = document.getElementById("editor");
    textarea.style.display = "none";
    const editor = monaco.editor.create(editorNode, {
      value: textarea.value,
      language: "c",
      theme: "vs-dark",
      automaticLayout: true,
      minimap: { enabled: false }
    });
    editor.onDidChangeModelContent(function() {
      textarea.value = editor.getValue();
    });
  });

  const submitForm = document.querySelector("[data-submit-form]");
  const submitButton = document.querySelector("[data-submit-button]");
  const submitProgress = document.querySelector("[data-submit-progress]");
  const submitProgressFill = document.querySelector("[data-submit-progress-fill]");
  const submitProgressLabel = document.querySelector("[data-submit-progress-label]");

  // Fake progress during the POST (keeps current UX).
  if (submitForm && submitButton && submitProgress) {
    let progress = 6;
    submitProgressFill && (submitProgressFill.style.width = `${progress}%`);
    submitProgressLabel && (submitProgressLabel.textContent = "Uploading…");

    const labels = [
      { at: 18, text: "Uploading…" },
      { at: 48, text: "Running tests…" },
      { at: 78, text: "Finalizing…" },
      { at: 92, text: "Almost done…" },
    ];

    let labelIndex = 0;
    let t = null;

    const startFakeProgress = () => {
      if (!submitProgressFill) return;
      t = window.setInterval(() => {
        progress = Math.min(progress + Math.random() * 8 + 1, 94);
        submitProgressFill.style.width = `${progress}%`;

        if (labelIndex < labels.length && progress >= labels[labelIndex].at) {
          submitProgressLabel && (submitProgressLabel.textContent = labels[labelIndex].text);
          labelIndex++;
        }
      }, 420);
    };

    const stopFakeProgress = () => {
      if (t) {
        window.clearInterval(t);
        t = null;
      }
    };

    submitForm.addEventListener("submit", function() {
      stopFakeProgress();
      progress = 6;
      submitProgressFill && (submitProgressFill.style.width = `${progress}%`);
      submitProgressLabel && (submitProgressLabel.textContent = "Uploading…");

      submitButton.disabled = true;
      submitButton.classList.add("is-loading");
      const span = submitButton.querySelector("span");
      span && (span.textContent = "Submitting");

      submitProgress.classList.add("is-visible");
      startFakeProgress();

      window.setTimeout(() => {
        stopFakeProgress();
        submitProgressFill && (submitProgressFill.style.width = `100%`);
        submitProgressLabel && (submitProgressLabel.textContent = "Submitted");
      }, 4200);
    });

    window.addEventListener("pageshow", () => stopFakeProgress());
    window.addEventListener("beforeunload", () => stopFakeProgress());
  }

  // Live status + auto-redirect on the *question* page.
  (function() {
    const live = document.querySelector("[data-live-submission]");
    const pill = document.querySelector("[data-live-status-pill]");
    const hint = document.querySelector("[data-live-submission-hint]");
    const fill = document.querySelector("[data-live-progress-fill]");
    if (!live || !pill) return;

    const questionId = {{ question.id }};
    const POLL_MS = 2000;
    const MAX_MS = 180000; // 3 minutes

    let startedAt = Date.now();

    const safeProgress = (n) => {
      if (n === undefined || n === null || Number.isNaN(n)) return 10;
      return n;
    };

    const setUI = (statusText, statusClass, progressPct) => {
      pill.textContent = statusText;
      pill.className = "status-pill " + (statusClass || "status-pending");
      if (fill) fill.style.width = safeProgress(progressPct) + "%";

      if (hint) {
        hint.textContent = statusClass === "status-accepted" ? "Redirecting…" : "Auto-refreshing results";
      }
    };

    const fetchLatest = async () => {
      const res = await fetch(`/api/submissions/latest/?question_id=${encodeURIComponent(questionId)}`, {
        headers: { "Accept": "application/json" }
      });
      if (!res.ok) throw new Error("Bad response");
      return await res.json();
    };

    const loop = async () => {
      try {
        const data = await fetchLatest();
        if (!data || !data.submission) {
          setUI("Waiting for submission…", "status-pending", 10);
          return;
        }

        const s = data.submission;
        const status = s.status;
        const statusDisplay = s.status_display;

        const progressMap = {
          pending: 20,
          running: 45,
          accepted: 100,
          wrong_answer: 100,
          tle: 100,
          compile_error: 100,
          runtime_error: 100,
          internal_error: 100,
        };

        const cssMap = {
          pending: "status-pending",
          running: "status-pending",
          accepted: "status-accepted",
          wrong_answer: "status-wrong_answer",
          tle: "status-tle",
          compile_error: "status-compile_error",
          runtime_error: "status-runtime_error",
          internal_error: "status-internal_error",
        };

        setUI(statusDisplay, cssMap[status] || "status-pending", progressMap[status] || 20);

        if (status === "accepted" || status === "wrong_answer" || status === "tle" || status === "compile_error" || status === "runtime_error" || status === "internal_error") {
          if (data.submission.id) {
            window.location.href = `/submissions/${data.submission.id}/`;
          }
        }
      } catch (e) {
        // silent; we keep polling.
      }
    };

    const tick = async () => {
      if (Date.now() - startedAt > MAX_MS) {
        setUI("Still working…", "status-pending", 25);
        return;
      }
      await loop();
    };

    setUI("Queued…", "status-pending", 25);
    tick();
    const interval = window.setInterval(tick, POLL_MS);
    window.addEventListener("beforeunload", () => window.clearInterval(interval));
  })();
</script>

{% endblock %}

